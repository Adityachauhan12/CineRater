# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=False

# ── Allowed Hosts (comma-separated; Railway domains added automatically) ─────
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Production (Railway): Railway auto-injects DATABASE_URL — just leave the others blank
# Local dev: leave DATABASE_URL blank and fill in the individual vars
DATABASE_URL=
DB_NAME=cinerater_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────────
# Production (Railway): Railway auto-injects REDIS_URL — just leave the others blank
# Local dev: leave REDIS_URL blank and fill in host/port
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL, e.g. https://cinerater.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True

# ── External APIs ─────────────────────────────────────────────────────────────
TMDB_API_KEY=your-tmdb-api-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your-gemini-api-key
EMBEDDING_MODEL=text-embedding-3-small

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_OAUTH2_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH2_CLIENT_SECRET=your-google-client-secret
